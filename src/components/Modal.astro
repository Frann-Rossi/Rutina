---
<div id="custom-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-fade-in">
    <div class="bg-card border border-white/10 rounded-2xl w-full max-w-md shadow-2xl overflow-hidden transform transition-all scale-95 opacity-0 modal-content">
        <div class="p-6">
            <h3 id="modal-title" class="text-xl font-bold text-gray-100">Confirmar acción</h3>
            <p id="modal-message" class="text-gray-400 mt-2">¿Estás seguro de que deseas realizar esta acción?</p>
        </div>
        <div class="bg-white/5 p-4 flex justify-end gap-3">
            <button id="modal-cancel" class="px-4 py-2 text-gray-400 hover:text-white transition-colors font-medium">
                Cancelar
            </button>
            <button id="modal-confirm" class="bg-red-500 hover:bg-red-600 text-white px-6 py-2 rounded-xl transition-all font-semibold shadow-lg shadow-red-500/20 active:scale-95">
                Confirmar
            </button>
        </div>
    </div>
</div>

<style>
    .modal-open .modal-content {
        @apply scale-100 opacity-100;
    }
</style>
